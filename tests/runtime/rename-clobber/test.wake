# Test for rename-over-directory behavior in fuse-waked
#
# Reproduces the cargo rsc/rsc_tool scenario:
# - Job A creates output in shared directory
# - Job B (no dependency on A) does temp-dir-rename over that directory
# - deep_unlink removes Job A's files
# - Both jobs "succeed" from Wake's perspective
# - Downstream job fails trying to use Job A's output
#
# This is intentional isolation behavior: the sandbox enforces the job's
# virtual view. With future CAS + per-job staging, jobs won't write
# directly to overlapping paths.

# Job 1: Create a file in target/release/ (like cargo building rsc)
def job1CreateBinary Unit =
    makeExecPlan ("sh", "-c", "mkdir -p target/release && echo 'binary_a' > target/release/binary_a", Nil) Nil
    | setPlanLabel "rename-clobber: job1 creates binary_a"
    | setPlanShare False
    | runJobWith defaultRunner
    | getJobOutputs

# Job 2: Simulate cargo's temp-dir-rename pattern (like cargo building rsc_tool)
# Creates temp dir, writes files, renames over target/
# NO dependency on job1 - doesn't declare job1's output as input
def job2RenameClobber Unit =
    makeExecPlan ("sh", "-c", "mkdir -p temp_target/release && echo 'binary_b' > temp_target/release/binary_b && mv temp_target target", Nil) Nil
    | setPlanLabel "rename-clobber: job2 renames temp to target"
    | setPlanShare False
    | runJobWith defaultRunner
    | getJobOutputs

# Downstream job: tries to use job1's output (like `cp` in original bug)
def copyJob1Output _ =
    # Get outputs from both jobs
    require Pass job1Outputs = job1CreateBinary Unit
    require Pass job2Outputs = job2RenameClobber Unit

    # Find job1's binary in its outputs
    require Some (Pair binaryA _) = find (matches `target/release/binary_a` _.getPathName) job1Outputs
    else failWithError "job1 didn't produce target/release/binary_a"

    # Try to read job1's file - this should fail because it was clobbered
    makeExecPlan ("cat", binaryA.getPathName, Nil) (binaryA, job2Outputs)
    | setPlanLabel "rename-clobber: read job1 output"
    | setPlanShare False
    | runJobWith defaultRunner
    | getJobStdout

# Entry point - runs the scenario
export def runScenario _ = copyJob1Output Unit

